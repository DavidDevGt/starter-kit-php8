#!/usr/bin/env bash
# First-run setup script — idempotent, safe to re-run
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${GREEN}[setup]${NC} $*"; }
warn()  { echo -e "${YELLOW}[setup]${NC} $*"; }
error() { echo -e "${RED}[setup]${NC} $*" >&2; exit 1; }

# ── 1. .env ──────────────────────────────────────────────────────────────────
if [ ! -f .env ]; then
    info "Copying .env.example → .env"
    cp .env.example .env
    warn "Review .env and set real secrets before running in production."
else
    info ".env already exists — skipping copy."
fi

# ── 2. Docker build & start ──────────────────────────────────────────────────
info "Building and starting containers..."
docker compose up -d --build

# ── 3. Wait for MySQL to be healthy ─────────────────────────────────────────
info "Waiting for MySQL to accept connections..."
attempt=0
max_attempts=30
until docker compose exec -T db mysqladmin ping -h 127.0.0.1 --silent 2>/dev/null; do
    attempt=$((attempt + 1))
    if [ "$attempt" -ge "$max_attempts" ]; then
        error "MySQL did not become healthy after ${max_attempts} attempts."
    fi
    printf '.'
    sleep 2
done
echo
info "MySQL is ready."

# ── 4. Wait for Redis to be healthy ─────────────────────────────────────────
info "Waiting for Redis..."
attempt=0
until docker compose exec -T cache redis-cli ping 2>/dev/null | grep -q PONG; do
    attempt=$((attempt + 1))
    if [ "$attempt" -ge 15 ]; then
        error "Redis did not become healthy."
    fi
    sleep 1
done
info "Redis is ready."

# ── 5. Composer install ──────────────────────────────────────────────────────
info "Installing Composer dependencies..."
docker compose exec -T app composer install --no-interaction --prefer-dist --optimize-autoloader

# ── 6. Run migrations ────────────────────────────────────────────────────────
info "Running database migrations..."
docker compose exec -T app php database/migrate.php run

# ── 7. Clear cache / logs ────────────────────────────────────────────────────
info "Clearing application cache..."
docker compose exec -T app sh -c 'find /var/www/html/storage/logs -name "*.log" -type f -delete 2>/dev/null || true'
docker compose exec -T app sh -c 'find /var/www/html/storage/cache -type f -delete 2>/dev/null || true'

info "Setup complete."
echo -e "\n  App:     http://localhost"
echo -e "  Mailpit: http://localhost:8025"
