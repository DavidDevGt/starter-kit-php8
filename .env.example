# =============================================================================
# SaaS Starter Kit — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit a real .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=local                           # local | production
APP_KEY=change-to-32-random-chars-here  # php -r "echo bin2hex(random_bytes(16));"
APP_DEBUG=false
APP_URL=http://localhost

# ── HTTP ports (docker-compose) ───────────────────────────────────────────────
HTTP_PORT=80
MAILPIT_PORT=8025

# ── Database ─────────────────────────────────────────────────────────────────
# In Docker: DB_HOST must match the service name ("db")
# Local dev without Docker: use 127.0.0.1
DB_HOST=db
DB_PORT=3306
DB_NAME=starter_kit_saas
DB_USER=saas_user
DB_PASS=change-this-db-password
DB_ROOT_PASSWORD=change-this-root-password

# ── Redis ─────────────────────────────────────────────────────────────────────
# In Docker: REDIS_HOST must match the service name ("cache")
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password

# ── Session & Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=redis     # redis | file
SESSION_LIFETIME=120     # minutes
CACHE_DRIVER=redis       # redis | array

# ── Mail ──────────────────────────────────────────────────────────────────────
# Development: Mailpit catches all outbound mail (UI at http://localhost:8025)
# Production:  Replace with Mailgun, SES, Postmark, etc.
MAIL_DRIVER=smtp
MAIL_HOST=mail           # "mail" = Mailpit container in dev
MAIL_PORT=1025           # Mailpit SMTP port (no auth needed in dev)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@saas.test
MAIL_FROM_NAME="SaaS Starter"
MAIL_ENCRYPTION=         # tls | ssl | (empty for dev)

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: stripe listen --forward-to localhost/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Price IDs — create in Stripe dashboard under Products
STRIPE_FREE_PRICE_ID=price_replace_me
STRIPE_STARTER_PRICE_ID=price_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local     # local | s3

# S3-compatible (AWS, DigitalOcean Spaces, MinIO, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=us-east-1
AWS_ENDPOINT=            # Leave empty for AWS; set for DO Spaces / MinIO
