{
    "name": "daviddevgt/starter-kit-saas",
    "description": "PHP 8 SaaS Starter Kit with multi-tenancy, RBAC, and Stripe billing",
    "type": "project",
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.4",
        "phpoffice/phpspreadsheet": "^1.28",
        "dompdf/dompdf": "^1.2",
        "stripe/stripe-php": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":     "phpunit",
        "migrate":  "php database/migrate.php run",
        "rollback": "php database/migrate.php rollback"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
