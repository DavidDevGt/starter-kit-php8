[mysqld]
# ── Character set ──────────────────────────────────────────────────────────────
character-set-server   = utf8mb4
collation-server       = utf8mb4_unicode_ci

# ── InnoDB tuning ──────────────────────────────────────────────────────────────
innodb_buffer_pool_size      = 256M    # ~70 % of available DB container memory
innodb_log_file_size         = 64M
innodb_flush_log_at_trx_commit = 1     # ACID-safe (set to 2 for max throughput)
innodb_flush_method          = O_DIRECT

# ── Connections ────────────────────────────────────────────────────────────────
max_connections              = 100
wait_timeout                 = 600
interactive_timeout          = 600

# ── Query cache (removed in 8.0 — left as comment for reference)
# query_cache_type = 0

# ── Slow query log → stderr ────────────────────────────────────────────────────
slow_query_log               = 1
slow_query_log_file          = /dev/stderr
long_query_time              = 2
log_queries_not_using_indexes= 1

# ── Binary log (required for replication / point-in-time recovery) ─────────────
# Uncomment in production if you need PITR backups
# log_bin                    = mysql-bin
# binlog_expire_logs_seconds = 604800   # 7 days
# binlog_format              = ROW

# ── General error log ─────────────────────────────────────────────────────────
log_error                    = /dev/stderr

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
